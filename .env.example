# ---------------------------------------------------------------------------
# Remote Worker Tracker System — Environment configuration
# Copy this file to `.env` and adjust values for your environment.
# ---------------------------------------------------------------------------

# Which settings module to load: config.settings.development | config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.development

# Security ------------------------------------------------------------------
# Generate a new key for production:  python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=django-insecure-change-me-in-production-0123456789abcdef
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database ------------------------------------------------------------------
# SQLite is used by default. Path is relative to BASE_DIR.
DATABASE_NAME=db.sqlite3

# Email ---------------------------------------------------------------------
# In development, emails are printed to the console by default.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=Remote Worker Tracker <no-reply@rwt.local>

# Security / sessions -------------------------------------------------------
SESSION_COOKIE_AGE=3600
SECURE_SSL_REDIRECT=False
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Application ---------------------------------------------------------------
TIME_ZONE=UTC
LANGUAGE_CODE=en-us

# Monitoring / screenshots --------------------------------------------------
SCREENSHOT_INTERVAL_SECONDS=600
SCREENSHOT_RETENTION_DAYS=90
IDLE_THRESHOLD_SECONDS=300
